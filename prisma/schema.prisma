generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CustomerType {
  PARTICULIER
  AANNEMER
  VASTGOEDBEHEERDER
  BEDRIJF
}

enum LeadStatus {
  NIEUW
  CONTACT_OPGENOMEN
  AFSPRAAK_GEPLAND
  OFFERTE_VERSTUURD
  GEWONNEN
  VERLOREN
}

enum Priority {
  LAAG
  NORMAAL
  HOOG
}

enum LeadImportSource {
  EMAIL
  WEBSITE
  FACEBOOK
  GOOGLE_ADS
}

enum LeadImportStatus {
  SUCCESS
  DUPLICATE
  ERROR
}

enum ProjectType {
  BADKAMER
  ZOLDER
  RENOVATIE
  SCHILDERWERK
  STUCWERK
  VLOER
  KEUKEN
  ONDERHOUD
  OVERIG
}

enum ProjectStatus {
  INTAKE
  OFFERTE
  GEPLAND
  BEZIG
  AFGEROND
  GEANNULEERD
}

enum QuoteStatus {
  CONCEPT
  VERZONDEN
  GEACCEPTEERD
  AFGEWEZEN
}

enum InvoiceStatus {
  CONCEPT
  VERZONDEN
  BETAALD
  TE_LAAT
}

enum TaskStatus {
  OPEN
  BEZIG
  AFGEROND
}

enum TaskRelationType {
  KLANT
  LEAD
  PROJECT
}

enum WorkOrderStatus {
  CONCEPT
  IN_UITVOERING
  GEREED
  GEFACTUREERD
}

enum ProjectAssetFolder {
  VOOR_FOTOS
  NA_FOTOS
  DOCUMENTEN
}

enum ProjectAssetType {
  FOTO
  PDF
  CONTRACT
  FACTUUR
}

enum UserRole {
  ADMIN
  MEDEWERKER
  VERKOPER
  BOEKHOUDING
}

model Customer {
  id            String         @id @default(cuid())
  name          String
  phone         String
  email         String
  address       String
  city          String
  type          CustomerType
  notes         String
  history       String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  leads         Lead[]
  projects      Project[]
  quotes        Quote[]
  invoices      Invoice[]
  tasks         Task[]
  workOrders    WorkOrder[]
  planningItems PlanningItem[]
}

model Lead {
  id             String            @id @default(cuid())
  title          String
  customerName   String
  phone          String?
  email          String?
  source         String
  importSource   LeadImportSource?
  status         LeadStatus        @default(NIEUW)
  priority       Priority          @default(NORMAAL)
  customerId     String?
  followUpTask   String?
  followUpTaskId String?
  notes          String
  message        String?
  projectType    String?
  city           String?
  budget         String?
  preferredDate  String?
  campaigns      String[]          @default([])
  externalId     String?           @unique
  importedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  customer       Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  project        Project?
  tasks          Task[]
  importLogs     LeadImportLog[]

  @@index([email])
  @@index([phone])
  @@index([importSource])
}

model LeadImportLog {
  id           String            @id @default(cuid())
  date         DateTime          @default(now())
  source       LeadImportSource?
  status       LeadImportStatus
  externalId   String?
  errorMessage String?
  rawPayload   Json
  leadId       String?
  lead         Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([source])
  @@index([status])
}

model Project {
  id            String         @id @default(cuid())
  title         String
  type          ProjectType
  status        ProjectStatus
  startDate     DateTime
  endDate       DateTime?
  budget        Float
  notes         String
  customerId    String
  leadId        String?        @unique
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead          Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quotes        Quote[]
  tasks         Task[]
  workOrders    WorkOrder[]
  planningItems PlanningItem[]
  assets        ProjectAsset[]
}

model WorkOrder {
  id          String          @id @default(cuid())
  number      String          @unique
  customerId  String
  projectId   String
  executor    String
  date        DateTime
  description String
  materials   String
  hours       Float
  status      WorkOrderStatus
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  planning    PlanningItem[]
}

model PlanningItem {
  id          String     @id @default(cuid())
  title       String
  customerId  String
  projectId   String
  workOrderId String?
  mechanic    String
  date        DateTime
  startTime   String
  endTime     String
  address     String
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([date])
}

model ProjectAsset {
  id         String             @id @default(cuid())
  projectId  String
  folder     ProjectAssetFolder
  type       ProjectAssetType
  name       String
  size       Int
  uploadedAt DateTime           @default(now())
  previewUrl String?
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Quote {
  id         String      @id @default(cuid())
  number     String      @unique
  status     QuoteStatus
  customerId String
  projectId  String?
  createdAt  DateTime    @default(now())
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lines      QuoteLine[]
  invoice    Invoice?
}

model QuoteLine {
  id          String @id @default(cuid())
  quoteId     String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Invoice {
  id         String        @id @default(cuid())
  number     String        @unique
  status     InvoiceStatus
  dueDate    DateTime
  amount     Float
  customerId String
  quoteId    String?       @unique
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quote      Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
}

model Task {
  id           String           @id @default(cuid())
  title        String
  deadline     DateTime
  status       TaskStatus
  relationType TaskRelationType
  relationId   String
  customerId   String?
  leadId       String?
  projectId    String?
  customer     Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lead         Lead?            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  project      Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([deadline])
}

model User {
  id    String   @id @default(cuid())
  name  String
  email String   @unique
  role  UserRole
}
